DISCORD_TOKEN=your_bot_token_here
PREFIX=!
OWNER_USER_ID=
BOT_STATUS_TEXT=Work Ticket Bot

# Dashboard
DASHBOARD_PORT=8787
DASHBOARD_TOKEN=change_me

# Persistent data file path (recommended for Koyeb volume)
# Example: /data/bot-data.json
BOT_DATA_PATH=

# Discord OAuth2 for dashboard login
DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=
DISCORD_REDIRECT_URI=

# Master access requires Discord role "Technical Lead"
# Optional: set explicit role id (preferred if role names can vary)
TECHNICAL_LEAD_ROLE_ID=
TECHNICAL_LEAD_ROLE_NAME=Technical Lead

# Optional slash fast registration guild
SLASH_GUILD_ID=

# Intents
ENABLE_GUILD_MEMBERS_INTENT=false
ENABLE_MESSAGE_CONTENT_INTENT=false

# Optional legacy fields
GOOGLE_SHEET_ID=
GOOGLE_SHEET_RANGE=JobList!A:Z
GOOGLE_SERVICE_ACCOUNT_JSON=
GOOGLE_SERVICE_ACCOUNT_FILE=
